<?xml version="1.0" encoding="UTF-8"?>
<!--
  App Sandbox is INTENTIONALLY disabled. See macos/Runner/README.md for
  the rationale and contributor rules (no runInShell: true, no PAT
  logging, etc). Do not re-enable without removing ActionRunnerService,
  GitService, and IdeLaunchService.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!--
	  Explicitly disable get-task-allow so Apple notarization accepts
	  the bundle. Xcode auto-injects this entitlement during signing in
	  some configurations, and any value other than false is a hard
	  notarization rejection (statusCode 4000).
	-->
	<key>com.apple.security.get-task-allow</key>
	<false/>
	<!--
	  Documented as sandbox-only, but hardened-runtime apps using
	  NSOpenPanel (file_picker plugin) can fail to surface the panel
	  without it. The panel is rendered by a sandboxed XPC service that
	  expects this entitlement to round-trip the chosen URL back to the
	  host process. Harmless when not strictly required.
	-->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!--
	  Required by flutter_secure_storage v10+ which sets
	  kSecUseDataProtectionKeychain = true by default. macOS 15 Sequoia
	  removed the legacy file-based keychain, so apps without this
	  entitlement receive -34018 (errSecMissingEntitlement) on any
	  Keychain write and fall back silently.

	  Uses $(TeamIdentifierPrefix) rather than $(AppIdentifierPrefix)
	  because Developer ID Manual signing in CI does not use a
	  provisioning profile, so $(AppIdentifierPrefix) — supplied by the
	  profile — would be undefined and Xcode pre-build would reject the
	  entitlement with a misleading "requires a provisioning profile"
	  error. $(TeamIdentifierPrefix) comes from the signing certificate
	  itself and resolves to the same team ID prefix in all configurations.
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
	</array>
</dict>
</plist>
